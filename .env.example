# Environment for the Docker Compose deployment (Dokploy → Environment, or a local
# `.env` beside docker-compose.yml). Copy to `.env` and fill in. NEVER commit real secrets.

# Postgres (user/db have defaults; the password is required)
POSTGRES_USER=thumb
POSTGRES_DB=thumb
POSTGRES_PASSWORD=change-me-strong

# Public URL of the app. Must be https:// in production so the session cookie is Secure.
APP_URL=https://thumb.davideghiotto.it

# Account creation: leave "false" to lock signup after the first user is created.
# Set "true" temporarily if you need to register an additional account.
ALLOW_SIGNUP=false

# Cloudflare R2 (S3-compatible object storage for image blobs)
#   R2_ENDPOINT = https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=yt-thumb-gen
